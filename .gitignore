# ============================================================
# Terraform
# ============================================================
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
terraform.tfvars       # Contains environment-specific values - never commit
*.tfplan

# ============================================================
# Lambda build artifacts — generated by Terraform archive_file
# ============================================================
.builds/
src/*.zip

# ============================================================
# Python
# ============================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv/
venv/
*.egg-info/
dist/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ============================================================
# IDE / OS
# ============================================================
.vscode/
.idea/
*.DS_Store
Thumbs.db

# Frontend
frontend/node_modules/
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
