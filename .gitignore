*.pyc
*.pyo
*.pyd
.env
.venv/
venv/
*.egg-info/
dist/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ============================================================
# IDE / OS
# ============================================================
.vscode/
.idea/
*.DS_Store
Thumbs.db
